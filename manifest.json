{
  "manifest_version": 3,
  "name": "Flow Image Automator",
  "version": "1.0.0",
  "description": "Bulk automate image generation on Google Flow with reference images and random cooldown",
  "permissions": [
    "storage",
    "downloads",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://labs.google/*",
    "https://aisandbox-pa.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Flow Image Automator"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
